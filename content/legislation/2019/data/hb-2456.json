{
  "measure": {
    "SessionKey": "2019R1",
    "MeasurePrefix": "HB",
    "MeasureNumber": 2456,
    "CatchLine": "Allows counties to partition and rezone up to 200 acres of lands within Eastern Oregon Border Economic Development Region from exclusive farm use to residential uses.",
    "MinorityCatchLine": null,
    "MeasureSummary": "\tAllows counties to <b>partition and</b> rezone up to 200 acres of lands within Eastern Oregon Border Economic Development Region from exclusive farm use to residential uses. \n\t\t<i>Continues any applicable farm use tax deferral and valuation on properties in region until redeveloped for sale or five years after rezoning. Applies to property tax years beginning on or after July 1, 2020, and before July 1, 2031.</i>] \n\t\t<i>Entitles owner to income tax credit of up to $5,000 on sale of new residential dwelling on rezoned property. Applies to tax years beginning on or after January 1, 2020, and before January 1, 2026.</i>] \n\tTakes effect on 91st day following adjournment sine die.",
    "CurrentVersion": "B",
    "RelatingToFull": "Relating to Eastern Oregon Border Economic Development Region housing; and prescribing an effective date.",
    "RelatingTo": "Relating to Eastern Oregon Border Economic Development Region housing; prescribing an effective date.",
