  "measure": {
    "SessionKey": "2019R1",
    "MeasurePrefix": "HB",
    "MeasureNumber": 2631,
    "CatchLine": "Directs Department of Corrections, in cooperation with Oregon Criminal Justice Commission, to establish pilot program to provide legal services that assist women who are incarcerated at Coffee Creek Correctional Facility to reenter and reintegrate into local communities, to reduce womens' vulnerability to domestic violence and to obtain employment, housing services and other benefits.",
    "MinorityCatchLine": null,
    "MeasureSummary": "\tDirects Department of Corrections, in cooperation with Oregon Criminal Justice Commission, to establish pilot program to provide legal services that assist women who are incarcerated at Coffee Creek Correctional Facility to reenter and reintegrate into local communities, to reduce womens' vulnerability to domestic violence and to obtain employment, housing services and other benefits. Sunsets December 31, 2021. \n\t\t<i>Appropriates moneys from General Fund</i>]<b> Increases appropriation to commission from General Fund</b>, for biennium beginning July 1, 2019, \t<i>to commission</i>] for purposes of carrying out provisions of Act. \n\tDeclares emergency, effective on passage.",
    "CurrentVersion": "B",
    "RelatingToFull": "Relating to legal services for women who are incarcerated; and declaring an emergency.",
