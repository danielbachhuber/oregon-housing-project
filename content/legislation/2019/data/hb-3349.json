{
  "measure": {
    "SessionKey": "2019R1",
    "MeasurePrefix": "HB",
    "MeasureNumber": 3349,
    "CatchLine": "Disallows, for purposes of personal income taxation, mortgage interest deduction for residence other than taxpayer's principal residence, unless taxpayer sells residence or actively markets residence for sale.",
    "MinorityCatchLine": null,
    "MeasureSummary": "\tDisallows, for purposes of personal income taxation, mortgage interest deduction for residence other than taxpayer's principal residence<b>, unless taxpayer sells residence or actively markets residence for sale</b>. Phases out allowable deduction for interest for principal residence based upon income. Disallows deduction for principal residence above threshold amount. <b> \n\t<b>Establishes Oregon Housing Opportunity Account.</b> Transfers amount equal to estimated increase in revenue attributable to restrictions on deduction of mortgage interest to \t<i>accounts in Oregon Housing Fund</i>]<b> account</b>. \n\tApplies to tax years beginning on or after January 1, 2019. \n\tTakes effect on 91st day following adjournment sine die.",
    "CurrentVersion": "A",
    "RelatingToFull": "Relating to tax treatment of mortgage interest; creating new provisions; amending ORS 316.695; and prescribing an effective date.",
    "RelatingTo": "Relating to tax treatment of mortgage interest; prescribing an effective date.",
