  "measure": {
    "SessionKey": "2019R1",
    "MeasurePrefix": "HB",
    "MeasureNumber": 2460,
    "CatchLine": "Provides that transferee of tax-deferred homestead is liable for amounts of outstanding deferred property taxes due on homestead if transferee is using homestead more than 90 days following taxpayer's death and is potential recipient of homestead under intestate succession or by devise or received homestead from estate of deceased taxpayer or right to homestead by gift or assignment from insolvent taxpayer.",
    "MinorityCatchLine": null,
    "MeasureSummary": "\tProvides that transferee of <b>tax-deferred</b> homestead is \t<i>not</i>] liable for amounts of outstanding deferred property taxes due on homestead if transferee \t<i>receives no interest in real or personal property from estate</i>]<b> is using homestead more than 90 days following taxpayer's death and is potential recipient of homestead under intestate succession or by devise or received homestead from estate of deceased taxpayer or right to homestead by gift or assignment from insolvent taxpayer</b>. \n\tTakes effect on 91st day following adjournment sine die.",
    "CurrentVersion": "A",
    "RelatingToFull": "Relating to the liability of transferees for deferred homestead property taxes; and prescribing an effective date.",
