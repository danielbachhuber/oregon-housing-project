{
  "measure": {
    "SessionKey": "2019R1",
    "MeasurePrefix": "SB",
    "MeasureNumber": 171,
    "CatchLine": "Authorizes Department of Human Services to remit payments for qualified residential treatment program services for certain children.",
    "MinorityCatchLine": null,
    "MeasureSummary": "\tAuthorizes Department of Human Services to remit payments for qualified residential treatment program services for certain children. \n\tProhibits department from placing child or ward in congregate care residential setting in this state if setting is not child-caring agency. Applies to placements occurring on or after September 1, 2019. \n\tProhibits department from placing child or ward in child-caring agency that is not qualified residential treatment program. Creates exceptions. Applies to placements occurring on or after July 1, 2020. \n\tDirects department to publish certain information regarding out-of-state placements and update information each month. \n\tDescribes qualified residential treatment program and requires certain procedures regarding department's placement of child or ward in qualified residential treatment program. \n\tModifies requirements for permanency hearing for children in voluntary placement. \n\tModifies definition of \"substitute care.\" \n\t<b>Creates exception to requirement that child-caring agency be incorporated.</b> \n\tDirects department and Oregon Health Authority to submit joint report regarding out-of-state placements to interim committees of Legislative Assembly relating to children no later than September 1, 2019. \n\tDeclares emergency, effective on passage.",
    "CurrentVersion": "C",
    "RelatingToFull": "Relating to children; and declaring an emergency.",
    "RelatingTo": "Relating to children; and declaring an emergency.",
    "AtTheRequestOf": "(at the request of Senate Interim Committee on Human Services)",
