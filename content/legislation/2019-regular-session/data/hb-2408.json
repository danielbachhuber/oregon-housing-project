{
  "measure": {
    "SessionKey": "2019R1",
    "MeasurePrefix": "HB",
    "MeasureNumber": 2408,
    "CatchLine": "Includes within definition of \"public works\" project for constructing, reconstructing or performing major renovation of privately owned road, highway, building, structure or improvement that is located in enterprise zone or for which qualified business firm received or will receive exemption from ad valorem property taxation and has total project cost estimated as equaling or exceeding $20 million.",
    "MinorityCatchLine": null,
    "MeasureSummary": "\t<b>Includes within definition of \"public works\" project for constructing, reconstructing or performing major renovation of privately owned road, highway, building, structure or improvement that is located in enterprise zone or for which qualified business firm received or will receive exemption from ad valorem property taxation and has total project cost estimated as equaling or exceeding $20 million.</b> \n\tDefines \"funds of a public agency,\" for purposes of applying prevailing rate of wage to projects for public works, to include tax credits or tax abatements that contractor engaged in public works project receives from state in connection with project. \n\t<b>Requires contractor or contractor's surety to file certified statements with, as appropriate, public agency that awarded contract for public works or sponsor of enterprise zone in which public works project is located.</b> \n\t\t<i>Becomes operative on January 1, 2020.</i>] \n\t\t<i>Takes effect on 91st day following adjournment sine die.</i>] \n\t<b>Becomes operative 91 days after effective date of Act. \n\t<b>Declares emergency, effective on passage.</b>",
    "CurrentVersion": "A",
    "RelatingToFull": "Relating to the application of a prevailing rate of wage to public works projects; creating new provisions; amending ORS 279C.800, 279C.810, 279C.827 and 279C.845; and declaring an emergency.",
    "RelatingTo": "Relating to the application of a prevailing rate of wage to public works projects; declaring an emergency.",
