{
  "measure": {
    "SessionKey": "2019R1",
    "MeasurePrefix": "SB",
    "MeasureNumber": 410,
    "CatchLine": "Eliminates Department of Consumer and Business Services regulation of recreational vehicle construction.",
    "MinorityCatchLine": null,
    "MeasureSummary": "\tEliminates Department of Consumer and Business Services regulation of recreational vehicle construction. Eliminates general definition of recreational vehicle for purposes of manufactured structure construction statutes. Creates substitute definition of recreational vehicle for use in certain statutes outside manufactured structure construction statutes. \n\tEliminates department regulation of recreational structure construction. Eliminates department regulation of construction and installation of yurts on campgrounds for use as transitional housing. \n\tRevises requirements for prefabricated structures that cease to qualify for exclusion from state building code regulations. \n\tPreserves, for land use law purposes, existing definitions of shared terms affected by state building code exclusions. \n\tExpands types of structures intended for out-of-state delivery exempted from plan review, inspection, electrical, plumbing or other state building code requirements.",
    "CurrentVersion": "B",
    "RelatingToFull": "Relating to exclusions from state building code regulation.",
    "RelatingTo": "Relating to exclusions from state building code regulation.",
