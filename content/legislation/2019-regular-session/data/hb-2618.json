{
  "measure": {
    "SessionKey": "2019R1",
    "MeasurePrefix": "HB",
    "MeasureNumber": 2618,
    "CatchLine": "Requires State Department of Energy to adopt by rule program for providing rebates for purchase, construction or installation of residential and certain nonresidential solar electric systems and paired solar and storage systems.",
    "MinorityCatchLine": null,
    "MeasureSummary": "\tRequires State Department of Energy to adopt by rule program for providing rebates for purchase, construction or installation of residential and <b>certain</b> nonresidential solar electric systems and paired solar and storage systems. Sets forth rebate limits under program. \n\tEstablishes Rooftop Solar Incentive Fund. Continuously appropriates moneys in fund to department to issue rebates. Limits total amount of rebates issued annually for nonresidential systems. Requires certain amount of rebates issued annually to be for systems installed for low or moderate income residential customers and low-income service providers. \n\t\t<i>Appropriates moneys from General Fund to department for deposit in Rooftop Solar Incentive Fund.</i>] \n\tRequires department to submit annual report on program to Legislative Assembly. \n\tSunsets January 2, 2024. \n\tTakes effect on 91st day following adjournment sine die.",
    "CurrentVersion": "B",
    "RelatingToFull": "Relating to solar incentives; and prescribing an effective date.",
    "RelatingTo": "Relating to solar incentives; and prescribing an effective date.",
