  "measure": {
    "SessionKey": "2019R1",
    "MeasurePrefix": "HB",
    "MeasureNumber": 2452,
    "CatchLine": "For purposes of eligibility of property for homestead property tax deferral program, creates floor of $250,000 for maximum allowable real market value of homestead.",
    "MinorityCatchLine": null,
    "MeasureSummary": "\tFor purposes of eligibility of property for homestead property tax deferral program, creates floor of $250,000 for maximum allowable real market value of homestead. Directs Department of Revenue to adjust maximum allowable real market value floor annually according to change in Consumer Price Index. \n\t<b>Allows claim for deferral to be filed late, with payment of fee. Modifies procedure for allowing claims for deferral in excess of maximum allowable for property tax year. \n\t<b>Extends sunset for deferral program.</b> \n\tTakes effect on 91st day following adjournment sine die.",
    "CurrentVersion": "A",
    "RelatingToFull": "Relating to the homestead property tax deferral program; creating new provisions; amending ORS 311.666, 311.668, 311.670, 311.672 and 311.694 and section 24, chapter 723, Oregon Laws 2011; and prescribing an effective date.",
    "RelatingTo": "Relating to the homestead property tax deferral program; prescribing an effective date.",
