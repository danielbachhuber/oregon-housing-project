  "measure": {
    "SessionKey": "2019R1",
    "MeasurePrefix": "SB",
    "MeasureNumber": 970,
    "CatchLine": "Limits applicable screening criteria for residential landlords.",
    "MinorityCatchLine": null,
    "MeasureSummary": "\tLimits applicable screening criteria for residential landlords. \n\tRequires facility landlords to provide tenant handbook regarding rights in selling tenant's manufactured dwelling or floating home. Requires landlord to allow tenant marketing manufactured dwelling or floating home for sale to sublease dwelling if landlord rents landlord's own units. \t<i>Shortens time landlord may evaluate prospective purchaser in facility.</i>] Increases civil penalties for certain facility landlords.",
    "CurrentVersion": "A",
    "RelatingToFull": "Relating to housing.",
